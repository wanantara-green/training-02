# ============================================
# KONFIGURASI LINGKUNGAN - WebGIS Zonasi
# ============================================
# Salin file ini menjadi .env dan isi nilai-nilai
# yang sesuai dengan lingkungan Anda.
# Jangan commit .env ke repository publik!
# ============================================

# GeoServer WFS Endpoint
# Ganti dengan URL server GeoServer Anda
GEOSERVER_URL=http://localhost:9597/geoserver

# Nama Workspace di GeoServer
GEOSERVER_WORKSPACE=zonasi

# (Optional) Nominatim Search Base URL
NOMINATIM_URL=https://nominatim.openstreetmap.org/search
